generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  account_id  Int      @id @default(autoincrement())
  password    String?  @db.VarChar(100)
  create_at   DateTime @db.Timestamp(6)
  status      String?  @db.VarChar(1)
  email       String?  @unique @db.VarChar(100)
  create_by   String?  @db.VarChar(100)
  update_by   String?  @db.VarChar(100)
  update_at   DateTime @db.Timestamp(6)
  Requestcode String?  @db.VarChar(100)
  Name        String?  @db.VarChar(50)
  Phone       String?  @db.VarChar(10)
  Avatar      String?
  Role        Int

  @@map("account")
}

model AccountAddress {
  account_address_id Int     @id @default(autoincrement())
  account_id         Int
  province_id        Int
  district_id        Int
  ward_id            Int
  accountPhoneNumber String? @db.VarChar(10)
  accountUsername    String? @db.VarChar(20)
  content            String? @db.VarChar(50)
  isDefault          Boolean

  @@map("accountaddress")
}

model Brand {
  brand_id   Int      @id @default(autoincrement())
  brand_name String?  @db.VarChar(50)
  create_by  String?  @db.VarChar(100)
  create_at  DateTime @db.Timestamp(6)
  update_by  String?  @db.VarChar(100)
  update_at  DateTime @db.Timestamp(6)

  @@map("brand")
}

model Contact {
  contact_id Int      @id @default(autoincrement())
  name       String
  phone      String
  email      String
  content    String
  create_by  String?  @db.VarChar(20)
  create_at  DateTime @db.Timestamp(6)
  status     String?  @db.VarChar(1)
  update_by  String?  @db.VarChar(20)
  update_at  DateTime? @db.Timestamp(6)

  @@map("contact")
}

model Delivery {
  delivery_id   Int      @id @default(autoincrement())
  delivery_name String?  @db.VarChar(100)
  price         Float
  create_at     DateTime @db.Timestamp(6)
  create_by     String?  @db.VarChar(20)
  status        String?  @db.VarChar(1)
  update_by     String?  @db.VarChar(20)
  update_at     DateTime? @db.Timestamp(6)

  @@map("delivery")
}

model Discount {
  disscount_id   Int      @id @default(autoincrement())
  discount_name  String?  @db.VarChar(100)
  discount_star  DateTime @db.Timestamp(6)
  discount_end   DateTime @db.Timestamp(6)
  discount_price Float
  discount_code  String?  @db.VarChar(10)
  create_at      DateTime @db.Timestamp(6)
  create_by      String?  @db.VarChar(100)
  update_by      String?  @db.VarChar(100)
  update_at      DateTime @db.Timestamp(6)
  quantity       Int

  @@map("discount")
}

model Districts {
  district_id   Int    @id @default(autoincrement())
  province_id   Int
  district_name String? @db.VarChar(50)
  type          String? @db.VarChar(20)

  @@map("districts")
}

model Feedback {
  feedback_id  Int      @id @default(autoincrement())
  account_id   Int
  product_id   Int
  genre_id     Int
  disscount_id Int
  rate_star    Int
  create_at    DateTime @db.Timestamp(6)
  create_by    String?  @db.VarChar(100)
  stastus      String?  @db.VarChar(1)
  update_by    String?  @db.VarChar(100)
  update_at    DateTime? @db.Timestamp(6)
  content      String?  @db.VarChar

  @@map("feedback")
}

model Genre {
  genre_id   Int      @id @default(autoincrement())
  genre_name String?  @db.VarChar(50)
  create_at  DateTime @db.Timestamp(6)
  create_by  String?  @db.VarChar(100)
  update_by  String?  @db.VarChar(100)
  update_at  DateTime @db.Timestamp(6)

  @@map("genre")
}

model Order {
  order_id       Int      @id @default(autoincrement())
  payment_id     Int
  delivery_id    Int
  oder_date      DateTime @db.Timestamp(6)
  total          Float
  account_id     Int
  status         String?  @db.VarChar(1)
  create_at      DateTime @db.Timestamp(6)
  create_by      String?  @db.VarChar(100)
  update_by      String?  @db.VarChar(100)
  update_at      DateTime @db.Timestamp(6)
  order_note     String?  @db.VarChar(200)
  orderAddressId Int?

  @@map("order")
}

model OrderAddress {
  orderAddressId   Int     @id @default(autoincrement())
  orderPhonenumber String? @db.VarChar(10)
  orderUsername    String? @db.VarChar(20)
  content          String? @db.VarChar(150)
  timesEdit        Int
  province_id      Int?
  district_id      Int?
  ward_id          Int?

  @@map("orderaddress")
}

model Payment {
  payment_id   Int      @id @default(autoincrement())
  payment_name String?  @db.VarChar(50)
  create_at    DateTime @db.Timestamp(6)
  create_by    String?  @db.VarChar(20)
  status       String?  @db.VarChar(1)
  update_by    String?  @db.VarChar(20)
  update_at    DateTime? @db.Timestamp(6)

  @@map("payment")
}

model Product {
  product_id     Int      @id @default(autoincrement())
  genre_id       Int
  disscount_id   Int
  brand_id       Int
  product_name   String?  @db.VarChar(200)
  price          Float
  view           BigInt
  buyturn        BigInt
  quantity       String?  @db.VarChar(10)
  status         String?  @db.VarChar(1)
  create_by      String?  @db.VarChar(100)
  create_at      DateTime @db.Timestamp(6)
  Type           Int?
  update_by      String?  @db.VarChar(100)
  update_at      DateTime @db.Timestamp(6)
  specifications String?  @db.VarChar
  image          String?  @db.VarChar
  description    String?  @db.VarChar

  @@map("product")
}

model ProductImages {
  product_img_id Int     @id @default(autoincrement())
  product_id     Int
  genre_id       Int
  disscount_id   Int
  image          String? @db.VarChar(500)

  @@map("productimages")
}

model Provinces {
  province_id   Int    @id @default(autoincrement())
  province_name String? @db.VarChar(50)
  type          String? @db.VarChar(20)

  @@map("provinces")
}

model ReplyFeedback {
  rep_feedback_id Int      @id @default(autoincrement())
  content         String?
  stastus         String?  @db.VarChar(1)
  create_at       DateTime @db.Timestamp(6)
  feedback_id     Int
  account_id      Int

  @@map("replyfeedback")
}

model Wards {
  ward_id     Int    @id @default(autoincrement())
  district_id Int
  ward_name   String? @db.VarChar(50)
  type        String? @db.VarChar(20)

  @@map("wards")
}

model Wishlist {
  wishlist_id Int      @id @default(autoincrement())
  account_id  Int
  product_id  Int
  create_at   DateTime @default(now()) @db.Timestamp(6)

  @@unique([account_id, product_id])
  @@map("wishlist")
}

model OrderDetail {
  order_id     Int
  product_id   Int
  quantity     Int
  price        Float
  genre_id     Int
  disscount_id Int
  status       String?  @db.VarChar(1)
  transection  String?  @db.VarChar(50)
  create_by    String?  @db.VarChar(20)
  create_at    DateTime @db.Timestamp(6)
  update_by    String?  @db.VarChar(20)
  update_at    DateTime @db.Timestamp(6)
  @@id([order_id, product_id])
  @@map("oder_detail")
}
